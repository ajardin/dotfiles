{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(docker compose ps)",
      "Bash(docker compose ps *)",
      "Bash(docker compose config *)",
      "mcp__datadog-mcp__search_datadog_logs",
      "mcp__datadog-mcp__search_datadog_metrics",
      "mcp__datadog-mcp__get_datadog_incident",
      "mcp__datadog-mcp__load_datadog_skill",
      "mcp__atlassian__getJiraIssue"
    ],
    "deny": [
      "Read(/**/.env)",
      "Read(/**/.env.*)",
      "Read(/**/secrets/**)",
      "Read(/**/credentials.json)",
      "Read(/**/*.pem)",
      "Read(/**/*.key)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/command-history.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py",
    "refreshInterval": 60
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    }
  },
  "awaySummaryEnabled": true,
  "autoUpdatesChannel": "latest",
  "model": "claude-fable-5[1m]",
  "effortLevel": "high",
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "theme": "dark-ansi",
  "skipAutoPermissionPrompt": true
}
