[user]
    name = Alexandre Jardin

[include]
    path = .gitconfig-corporate

[includeIf "gitdir:~/Projects/ajardin/"]
    path = .gitconfig-opensource

[alias]
    aliases = config --get-regexp alias
    fp = fetch --all --prune --tags --force
    last = log --graph --pretty=tformat:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%an %cr)%Creset' -n15
    oops = commit --amend --no-edit --date=now
    rb = "!git rebase $(git symbolic-ref --short refs/remotes/origin/HEAD)"
    st = status

[checkout]
    defaultRemote = origin

[color]
    ui = auto

[core]
    compression = 9
    excludesfile = ~/.gitignore
    fsmonitor = true
    pager = cat
    untrackedCache = true

[credential]
    helper = osxkeychain

[diff]
    colorMoved = dimmed-zebra

[help]
    autocorrect = 10

[init]
    defaultBranch = main

[interactive]
    diffFilter = delta --color-only

[merge]
    conflictstyle = diff3

[pull]
    rebase = true

[push]
    autoSetupRemote = true
    default = current

[rerere]
    enabled = true
